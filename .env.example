# העתק/י קובץ זה ל-.env ומלא/י את הערכים האמיתיים.
# ⚠️ אין להעלות את קובץ .env לגיטהאב או לשתף אותו — הוא מכיל סודות.

# מפתח ה-API של Claude (מ-console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# פרטי WhatsApp Cloud API (מ-Meta for Developers > WhatsApp > API Setup)
WHATSAPP_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# מחרוזת סודית שאת/ה בוחר/ת בעצמך — צריך להזין אותה גם ב-Meta בעת הגדרת ה-webhook.
# יכולה להיות כל מחרוזת (למשל: my-lashes-bot-secret-2026)
VERIFY_TOKEN=בחר-מחרוזת-סודית-כלשהי

# פורט (בענן זה נקבע אוטומטית — אפשר להשאיר)
PORT=3000

# (אופציונלי) כתובת ה-Web App של Google Apps Script לתיעוד שיחות בגוגל שיטס.
# ראי הוראות הקמה ב-README תחת "תיעוד שיחות בגוגל שיטס". אם לא מוגדר — הבוט
# פשוט לא מתעד, בלי שום שגיאה.
GOOGLE_SHEETS_WEBHOOK_URL=

# (אופציונלי) מענה אוטומטי למיילים של לקוחות. ראי הוראות הקמה ב-README תחת
# "מענה אוטומטי למיילים". אם לא מוגדרים — התכונה כבויה, הבוט ממשיך כרגיל.
# EMAIL_APP_PASSWORD היא "סיסמת אפליקציה" (App Password) של Google — לא הסיסמה
# הרגילה שלך! מייצרים אותה ב-myaccount.google.com/apppasswords.
EMAIL_USER=shopbyloria@gmail.com
EMAIL_APP_PASSWORD=
